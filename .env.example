# Demo mode — deploy to Vercel without a database
# When DEMO_MODE=true, all API routes return mock data and no DATABASE_URL is required.
DEMO_MODE=true

# Database (required when DEMO_MODE=false)
DATABASE_URL="postgresql://username:password@localhost:5432/ajuni_foundation?schema=public"

# NextAuth (required for auth in all modes)
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET can be any random string. It is auto-generated in demo mode for previews only.
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Google OAuth (optional — only needed for resident Google sign-in)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Razorpay (optional — payments fall back to mock orders when keys are missing)
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# Cloudinary (optional — only needed for real photo uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_UPLOAD_PRESET="ajuni_feeder_photos"
